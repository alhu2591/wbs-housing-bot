# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# ── Optional ──────────────────────────────────────────────────────────────────
# HTTP proxy if needed (e.g. on VPS with blocked IPs)
# PROXY_URL=http://user:pass@host:port

# Scraping interval in minutes (default: 5)
SCRAPE_INTERVAL=5

# Default price filter (can be changed via /set_price)
DEFAULT_MAX_PRICE=600

# Storage path (default: project root for local, /tmp for server)
# DATA_DIR=/tmp
