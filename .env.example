BOT_TOKEN=your_telegram_bot_token_here
CHAT_ID=your_telegram_chat_id_here

# ScraperAPI key (free: 1000 req/month) — get at scraperapi.com
# REQUIRED for Railway/Render deployments (cloud IPs are blocked by housing sites)
SCRAPER_API_KEY=your_scraperapi_key_here

# Optional proxy (http://user:pass@host:port)
PROXY_URL=

# Scraping interval in minutes (default: 2)
SCRAPE_INTERVAL=2

# Default filters (can be changed via bot commands)
DEFAULT_MAX_PRICE=600
DEFAULT_ROOMS=
DEFAULT_AREA=
